---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacts — ξ Chasing Wanderlust"
  description="Get in touch — collaborations, questions, or just to say hello."
>
  <div class="contacts-page">
    <div class="container">

      <header class="contacts-header fade-up">
        <div class="contacts-num">05</div>
        <div class="contacts-info">
          <h1 class="contacts-title">Contacts</h1>
          <p class="contacts-desc">Collaborations, questions, or just to say hello.</p>
        </div>
      </header>

      <hr class="rule" />

      <div class="contacts-body fade-up fade-up-1">

        <div class="contacts-intro">
          <p>
            I'm always open to conversations about travel, food, books, and everything in between.
            Whether you'd like to collaborate, share a recommendation, or simply connect —
            feel free to reach out.
          </p>
        </div>

        <div class="contacts-grid">

          <div class="contact-block reveal">
            <span class="contact-label">Instagram</span>
            <a
              href="https://www.instagram.com/senorita.xi/"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-value contact-link"
            >
              @senorita.xi
              <span class="contact-arrow">↗</span>
            </a>
            <p class="contact-note">
              The most immediate place to find me — stories, posts, and moments from the road.
            </p>
          </div>

          <div class="contact-block reveal" style="transition-delay: 80ms">
            <span class="contact-label">Collaborations</span>
            <p class="contact-value">
              Open to travel partnerships, restaurant features, book & film collaborations,
              and wellness brand projects that align with the spirit of this space.
            </p>
          </div>

          <div class="contact-block reveal" style="transition-delay: 160ms">
            <span class="contact-label">Say Hello</span>
            <p class="contact-value">
              Have a destination recommendation? A book I must read? A restaurant not to miss?
              I genuinely love hearing from people who share the same curiosities.
            </p>
          </div>

        </div>

        <div class="contacts-ig-cta reveal">
          <a
            href="https://www.instagram.com/senorita.xi/"
            target="_blank"
            rel="noopener noreferrer"
            class="ig-cta-btn"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
            Send a message on Instagram
          </a>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contacts-page {
    padding-block: clamp(2.5rem, 6vw, 5rem) clamp(4rem, 8vw, 7rem);
  }

  .contacts-header {
    display: flex;
    align-items: flex-end;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .contacts-num {
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 400;
    color: var(--cream);
    line-height: 1;
    flex-shrink: 0;
    user-select: none;
  }

  .contacts-info { padding-bottom: 0.5rem; }

  .contacts-title {
    font-family: var(--font-label);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .contacts-desc {
    font-size: 0.9375rem;
    color: var(--mist);
    font-style: italic;
    margin-bottom: 0;
    max-width: 50ch;
  }

  .rule { margin-bottom: 3rem; }

  .contacts-intro {
    max-width: 56ch;
    margin-bottom: 3.5rem;
  }

  .contacts-intro p {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--mist);
    font-style: italic;
    margin-bottom: 0;
  }

  .contacts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    margin-bottom: 3.5rem;
  }

  .contact-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--cream);
  }

  .contact-label {
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .contact-value {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-style: italic;
    color: var(--ink);
    line-height: 1.4;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    position: relative;
    transition: color 0.2s;
  }

  .contact-link:hover { color: var(--accent); }

  .contact-arrow {
    font-style: normal;
    font-size: 0.875rem;
    opacity: 0.5;
    transition: opacity 0.2s, transform 0.2s;
  }

  .contact-link:hover .contact-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
  }

  .contact-note {
    font-size: 0.875rem;
    color: var(--mist);
    line-height: 1.65;
    margin-bottom: 0;
  }

  /* CTA button */
  .contacts-ig-cta {
    padding-top: 2.5rem;
    border-top: 1px solid var(--cream);
  }

  .ig-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-label);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ivory);
    background-color: var(--accent);
    padding: 0.8rem 1.75rem;
    border-radius: 2px;
    text-decoration: none;
    transition: background-color 0.2s, transform 0.2s;
  }

  .ig-cta-btn:hover {
    background-color: var(--ink);
    transform: translateY(-1px);
  }

  @media (max-width: 860px) {
    .contacts-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 540px) {
    .contacts-grid { grid-template-columns: 1fr; }
  }
</style>

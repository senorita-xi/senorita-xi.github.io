---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategorySection from '@/components/CategorySection.astro';
import InstagramGrid from '@/components/InstagramGrid.astro';
import { getCollection } from 'astro:content';

// Fetch latest 3 posts from each collection
const footprints   = (await getCollection('footprints',   ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
const savour       = (await getCollection('savour',       ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
const pagesFrames  = (await getCollection('pages-frames', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
const inMotion     = (await getCollection('in-motion',    ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1 class="hero-title">
          <span class="line-xi fade-up">ξ</span>
          <span class="line-chasing fade-up fade-up-1">Chasing</span>
          <span class="line-wanderlust fade-up fade-up-2">Wanderlust</span>
        </h1>
        <div class="hero-rule fade-up fade-up-3"></div>
        <p class="hero-sub fade-up fade-up-4">
          Wandering the world, one bite, book & mile at a time.
        </p>
      </div>
    </div>
  </section>

  <!-- Category Sections -->
  <div class="container">
    <CategorySection
      number="01"
      label="Footprints"
      href="/footprints/"
      posts={footprints}
    />
    <CategorySection
      number="02"
      label="Savour"
      href="/savour/"
      posts={savour}
    />
    <CategorySection
      number="03"
      label="Pages & Frames"
      href="/pages-frames/"
      posts={pagesFrames}
    />
    <CategorySection
      number="04"
      label="In Motion"
      href="/in-motion/"
      posts={inMotion}
    />
  </div>

  <!-- Instagram -->
  <InstagramGrid />
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(4rem, 10vw, 8rem);
    border-bottom: 1px solid var(--cream);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.025em;
    margin-bottom: 2rem;
  }

  /* Line 1: ξ — slate blue, italic, smaller — a decorative mark */
  .line-xi {
    font-size: clamp(2.75rem, 7vw, 5.5rem);
    font-style: italic;
    color: var(--accent);
    letter-spacing: -0.01em;
    margin-bottom: 0.1em;
  }

  /* Line 2: Chasing — mist, upright — recedes, creates pause */
  .line-chasing {
    font-size: clamp(3rem, 8vw, 7rem);
    font-style: normal;
    font-weight: 400;
    color: var(--mist);
    margin-bottom: 0.05em;
  }

  /* Line 3: Wanderlust — ink, bold italic — dominant, the landing point */
  .line-wanderlust {
    font-size: clamp(3rem, 8vw, 7rem);
    font-style: italic;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.03em;
  }

  .hero-rule {
    width: clamp(2.5rem, 6vw, 4.5rem);
    height: 1px;
    background-color: var(--accent);
    margin-bottom: 1.25rem;
    opacity: 0.5;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 1.8vw, 1.0625rem);
    font-style: italic;
    color: var(--mist);
    max-width: 40ch;
    line-height: 1.7;
    margin-bottom: 0;
  }
</style>

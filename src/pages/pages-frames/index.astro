---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('pages-frames', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Pages & Frames — ξ Chasing Wanderlust"
  description="Reviews of books and films that stayed with me long after I finished them."
>
  <div class="category-page">
    <div class="container">
      <header class="category-header fade-up">
        <div class="category-num">03</div>
        <div class="category-info">
          <h1 class="category-title">Pages & Frames</h1>
          <p class="category-desc">Reviews of books and films that stayed with me long after I finished them.</p>
        </div>
      </header>

      <hr class="rule" />

      <div class="posts-grid">
        {posts.map((post, i) => (
          <PostCard
            title={post.data.title}
            href={`/pages-frames/${post.slug}/`}
            coverImage={post.data.coverImage}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            location={post.data.location}
            delay={i * 60}
          />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .category-page { padding-block: clamp(2.5rem, 6vw, 5rem); }
  .category-header { display: flex; align-items: flex-end; gap: 2rem; margin-bottom: 1.5rem; }
  .category-num { font-family: var(--font-display); font-size: clamp(4rem, 10vw, 8rem); font-weight: 400; color: var(--cream); line-height: 1; flex-shrink: 0; user-select: none; }
  .category-info { padding-bottom: 0.5rem; }
  .category-title { font-family: var(--font-label); font-size: 0.875rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink); margin-bottom: 0.5rem; }
  .category-desc { font-size: 0.9375rem; color: var(--mist); font-style: italic; margin-bottom: 0; max-width: 50ch; }
  .rule { margin-bottom: 2.5rem; }
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.25rem, 3vw, 2rem); }
  @media (max-width: 900px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .posts-grid { grid-template-columns: 1fr; } }
</style>

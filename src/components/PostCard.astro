---
interface Props {
  title: string;
  href: string;
  coverImage: string;
  description: string;
  pubDate: Date;
  category: string;
  location?: string;
  delay?: number;
}

const { title, href, coverImage, description, pubDate, category, location, delay = 0 } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card reveal" style={`transition-delay: ${delay}ms`}>
  <a href={href} class="card-link" tabindex="-1" aria-hidden="true">
    <div class="card-image-wrap">
      <img
        src={coverImage}
        alt={title}
        loading="lazy"
        width="400"
        height="540"
      />
      <div class="card-overlay">
        <span class="overlay-read">Read →</span>
      </div>
    </div>
  </a>

  <div class="card-body">
    <div class="card-meta">
      {location && <span class="card-location">{location}</span>}
      {location && <span class="meta-dot">·</span>}
      <time class="card-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
    </div>

    <h3 class="card-title">
      <a href={href} class="card-title-link">{title}</a>
    </h3>

    <p class="card-desc">{description}</p>
  </div>
</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background-color: var(--cream);
    border-radius: 2px;
  }

  .card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card:hover .card-image-wrap img {
    transform: scale(1.05);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 22, 18, 0);
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 1.25rem;
    transition: background 0.3s ease;
  }

  .post-card:hover .card-overlay {
    background: rgba(26, 22, 18, 0.2);
  }

  .overlay-read {
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: #fff;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s, transform 0.3s;
  }

  .post-card:hover .overlay-read {
    opacity: 1;
    transform: none;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .card-location {
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .meta-dot {
    color: var(--cream);
    font-size: 0.6rem;
  }

  .card-date {
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--mist);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 400;
    font-style: italic;
    line-height: 1.3;
  }

  .card-title-link {
    position: relative;
    background-image: linear-gradient(var(--ink), var(--ink));
    background-size: 0% 1px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    transition: background-size 0.3s ease;
  }

  .card-title-link:hover {
    background-size: 100% 1px;
  }

  .card-desc {
    font-size: 0.875rem;
    color: var(--mist);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0;
  }
</style>

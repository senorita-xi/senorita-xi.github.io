---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLang, useTranslations } from '@/i18n/utils';

const lang = getLang(Astro.currentLocale);
const t    = useTranslations(lang);

const socials = [
  {
    platform: 'Instagram',
    handle: '@senorita.xi',
    url: 'https://www.instagram.com/senorita.xi/',
    noteKey: 'connect.ig.note' as const,
    ctaKey: 'connect.follow' as const,
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    platform: 'Strava',
    handle: 'senorita.xi',
    url: 'https://www.strava.com/athletes/71780139',
    noteKey: 'connect.strava.note' as const,
    ctaKey: 'connect.follow' as const,
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169"/></svg>`,
  },
  {
    platform: 'YouTube',
    handle: '@NEparjenite_kartofki_na_xi',
    url: 'https://www.youtube.com/@NEparjenite_kartofki_na_xi',
    noteKey: 'connect.yt.note' as const,
    ctaKey: 'connect.subscribe' as const,
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/></svg>`,
  },
] as const;
---

<BaseLayout
  lang={lang}
  title={`${t('nav.contacts')} — ξ Chasing Wanderlust`}
  description={t('connect.desc')}
>
  <div class="connect-page">
    <div class="container">

      <header class="connect-header fade-up">
        <h1 class="connect-title">{t('nav.contacts')}</h1>
        <p class="connect-intro">{t('connect.intro')}</p>
      </header>

      <hr class="rule" />

      <div class="socials-list">
        {socials.map((s, i) => (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            class="social-card reveal"
            style={`transition-delay: ${i * 90}ms`}
          >
            <div class="social-icon" set:html={s.icon} />

            <div class="social-body">
              <span class="social-platform">{s.platform}</span>
              <span class="social-handle">{s.handle}</span>
              <p class="social-note">{t(s.noteKey)}</p>
            </div>

            <div class="social-cta">
              <span class="cta-label">{t(s.ctaKey)}</span>
              <span class="cta-arrow">↗</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .connect-page {
    padding-block: clamp(3rem, 7vw, 6rem) clamp(5rem, 10vw, 8rem);
  }

  .connect-header {
    margin-bottom: 1.5rem;
  }

  .connect-title {
    font-family: var(--font-label);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 0.75rem;
  }

  .connect-intro {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-style: italic;
    color: var(--mist);
    margin-bottom: 0;
  }

  .rule { margin-bottom: clamp(2rem, 4vw, 3rem); }

  /* ── Social cards ── */
  .socials-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .social-card {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    padding-block: clamp(1.5rem, 3vw, 2.25rem);
    border-bottom: 1px solid var(--cream);
    text-decoration: none;
    color: inherit;
    transition: background-color 0.2s;
    border-radius: 2px;
  }

  .social-card:first-child { border-top: 1px solid var(--cream); }

  .social-card:hover { background-color: var(--cream); }
  .social-card:hover { margin-inline: -1rem; padding-inline: 1rem; }

  /* Icon */
  .social-icon {
    color: var(--mist);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .social-card:hover .social-icon { color: var(--accent); }

  /* Body */
  .social-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .social-platform {
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .social-handle {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-style: italic;
    color: var(--ink);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .social-note {
    font-size: 0.875rem;
    color: var(--mist);
    line-height: 1.5;
    margin-bottom: 0;
  }

  /* CTA */
  .social-cta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .cta-label {
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mist);
    transition: color 0.2s;
  }

  .cta-arrow {
    font-size: 0.875rem;
    color: var(--mist);
    opacity: 0.5;
    transition: opacity 0.2s, transform 0.2s;
  }

  .social-card:hover .cta-label,
  .social-card:hover .cta-arrow {
    color: var(--accent);
  }

  .social-card:hover .cta-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
  }

  @media (max-width: 540px) {
    .social-card { grid-template-columns: 2rem 1fr; }
    .social-cta { display: none; }
  }
</style>

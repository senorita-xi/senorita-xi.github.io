---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLang, useTranslations } from '@/i18n/utils';

/*
  PHOTO SETUP
  ─────────────────────────────────────────────────────────────
  Add your portrait photo at:  public/images/me.jpg
  Then set `hasPhoto = true` below.
  ─────────────────────────────────────────────────────────────
*/
const hasPhoto = false; // ← set to true once public/images/me.jpg exists

const lang = getLang(Astro.currentLocale);
const t    = useTranslations(lang);
---

<BaseLayout
  lang={lang}
  title={`${t('nav.contacts')} — ξ Chasing Wanderlust`}
  description={t('contacts.desc')}
>
  <div class="contacts-page">

    <!-- Portrait + Intro -->
    <div class="portrait-section">
      <div class="container portrait-inner">

        <div class="portrait-photo-col fade-up">
          {hasPhoto ? (
            <img src="/images/me.jpg" alt="Portrait" class="portrait-img" width="480" height="640" />
          ) : (
            <div class="portrait-placeholder" aria-hidden="true">
              <div class="placeholder-inner">
                <span class="placeholder-xi">ξ</span>
                <p class="placeholder-hint">
                  Add <code>public/images/me.jpg</code><br />
                  and set <code>hasPhoto&nbsp;=&nbsp;true</code>
                </p>
              </div>
            </div>
          )}
        </div>

        <div class="portrait-text-col fade-up fade-up-1">
          <div class="portrait-eyebrow">05</div>
          <h1 class="portrait-title">{t('nav.contacts')}</h1>
          <hr class="portrait-rule" />
          <p class="portrait-intro">{t('contacts.intro')}</p>
          <a href="https://www.instagram.com/senorita.xi/" target="_blank" rel="noopener noreferrer" class="portrait-ig-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
            @senorita.xi
          </a>
        </div>

      </div>
    </div>

    <!-- Info Cards -->
    <div class="container">
      <div class="contacts-grid">
        <div class="contact-block reveal">
          <span class="contact-label">{t('contacts.instagram.label')}</span>
          <a href="https://www.instagram.com/senorita.xi/" target="_blank" rel="noopener noreferrer" class="contact-value contact-link">
            @senorita.xi <span class="contact-arrow">↗</span>
          </a>
          <p class="contact-note">{t('contacts.instagram.note')}</p>
        </div>
        <div class="contact-block reveal" style="transition-delay: 90ms">
          <span class="contact-label">{t('contacts.collab.label')}</span>
          <p class="contact-value collab-text">{t('contacts.collab.text')}</p>
        </div>
        <div class="contact-block reveal" style="transition-delay: 180ms">
          <span class="contact-label">{t('contacts.hello.label')}</span>
          <p class="contact-value collab-text">{t('contacts.hello.text')}</p>
        </div>
      </div>

      <div class="contacts-cta reveal">
        <a href="https://www.instagram.com/senorita.xi/" target="_blank" rel="noopener noreferrer" class="ig-cta-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
          </svg>
          {t('ui.sendMessage')}
        </a>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .contacts-page { padding-bottom: clamp(4rem, 8vw, 7rem); }

  .portrait-section { background-color: var(--cream); padding-block: clamp(3rem, 7vw, 6rem); margin-bottom: clamp(3rem, 6vw, 5rem); }
  .portrait-inner { display: grid; grid-template-columns: 1fr 1.5fr; gap: clamp(2rem, 5vw, 5rem); align-items: center; }

  .portrait-photo-col { position: relative; }
  .portrait-img { width: 100%; aspect-ratio: 3/4; object-fit: cover; object-position: center top; display: block; }
  .portrait-placeholder { width: 100%; aspect-ratio: 3/4; background-color: var(--ivory); border: 1px dashed var(--mist); display: flex; align-items: center; justify-content: center; }
  .placeholder-inner { display: flex; flex-direction: column; align-items: center; gap: 1.25rem; text-align: center; padding: 1.5rem; }
  .placeholder-xi { font-family: var(--font-display); font-size: clamp(3rem, 8vw, 5rem); font-style: italic; color: var(--cream); line-height: 1; user-select: none; }
  .placeholder-hint { font-family: var(--font-label); font-size: 0.75rem; letter-spacing: 0.04em; color: var(--mist); line-height: 1.7; margin-bottom: 0; }
  .placeholder-hint code { font-family: monospace; font-size: 0.7rem; color: var(--accent); }

  .portrait-text-col { display: flex; flex-direction: column; gap: 1rem; }
  .portrait-eyebrow { font-family: var(--font-display); font-size: clamp(3rem, 7vw, 6rem); font-weight: 400; color: var(--ivory); line-height: 1; user-select: none; }
  .portrait-title { font-family: var(--font-label); font-size: 0.875rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink); margin-top: -0.5rem; }
  .portrait-rule { border: none; border-top: 1px solid var(--mist); opacity: 0.35; margin-block: 0.5rem; }
  .portrait-intro { font-family: var(--font-body); font-size: 1.0625rem; font-style: italic; color: var(--ink); line-height: 1.8; margin-bottom: 0.5rem; opacity: 0.75; }
  .portrait-ig-link { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-label); font-size: 0.8125rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); text-decoration: none; transition: gap 0.2s, color 0.2s; }
  .portrait-ig-link:hover { color: var(--ink); gap: 0.75rem; }

  .contacts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.5rem, 3vw, 3rem); margin-bottom: 3rem; }
  .contact-block { display: flex; flex-direction: column; gap: 0.75rem; padding-top: 1.5rem; border-top: 1px solid var(--cream); }
  .contact-label { font-family: var(--font-label); font-size: 0.75rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); }
  .contact-value { font-family: var(--font-display); font-size: 1.125rem; font-style: italic; color: var(--ink); line-height: 1.4; }
  .collab-text { font-family: var(--font-body); font-size: 0.9375rem; font-style: normal; line-height: 1.7; color: var(--mist); }
  .contact-link { display: inline-flex; align-items: center; gap: 0.35rem; text-decoration: none; transition: color 0.2s; }
  .contact-link:hover { color: var(--accent); }
  .contact-arrow { font-style: normal; font-size: 0.875rem; opacity: 0.45; transition: opacity 0.2s, transform 0.2s; }
  .contact-link:hover .contact-arrow { opacity: 1; transform: translate(2px, -2px); }
  .contact-note { font-size: 0.875rem; color: var(--mist); line-height: 1.65; margin-bottom: 0; }

  .contacts-cta { padding-top: 2.5rem; border-top: 1px solid var(--cream); }
  .ig-cta-btn { display: inline-flex; align-items: center; gap: 0.65rem; font-family: var(--font-label); font-size: 0.8125rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ivory); background-color: var(--accent); padding: 0.85rem 2rem; border-radius: 1px; text-decoration: none; transition: background-color 0.25s, transform 0.2s; }
  .ig-cta-btn:hover { background-color: var(--ink); transform: translateY(-1px); }

  @media (max-width: 800px) {
    .portrait-inner { grid-template-columns: 1fr; }
    .portrait-photo-col { max-width: 320px; margin-inline: auto; width: 100%; }
    .portrait-eyebrow { font-size: clamp(2rem, 10vw, 4rem); }
  }
  @media (max-width: 860px) { .contacts-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .contacts-grid { grid-template-columns: 1fr; } }
</style>

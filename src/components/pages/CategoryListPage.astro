---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCategoryPosts, bareSlug } from '@/i18n/paths';
import { getLang, useTranslations, localHref } from '@/i18n/utils';
import type { UIKey } from '@/i18n/ui';

interface Props {
  collection: 'footprints' | 'savour' | 'pages-frames' | 'in-motion';
  labelKey: UIKey;
  descKey: UIKey;
}

const { collection, labelKey, descKey } = Astro.props;

const lang = getLang(Astro.currentLocale);
const t    = useTranslations(lang);

const label    = t(labelKey);
const desc     = t(descKey);
const hrefBase = localHref(`/${collection}/`, lang);

const posts = await getCategoryPosts(collection, lang);
---

<BaseLayout
  lang={lang}
  title={`${label} — ξ Chasing Wanderlust`}
  description={desc}
>
  <div class="category-page">
    <div class="container">
      <header class="category-header fade-up">
        <h1 class="category-title">{label}</h1>
        <p class="category-desc">{desc}</p>
      </header>

      <hr class="rule" />

      <div class="posts-grid">
        {posts.map((post, i) => (
          <PostCard
            title={post.data.title}
            href={`${hrefBase}${bareSlug(post.slug)}/`}
            coverImage={post.data.coverImage}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            location={post.data.location}
            delay={i * 60}
          />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .category-page { padding-block-end: clamp(2.5rem, 6vw, 5rem); }
  .category-header { margin-bottom: 1.5rem; }
  .category-title { font-family: var(--font-display); font-size: 2.25rem; font-style: italic; font-weight: 700; letter-spacing: 0.01em; text-transform: none; color: var(--ink); margin-bottom: 0.5rem; }
  .category-desc { font-size: 0.9375rem; color: var(--mist); font-style: italic; margin-bottom: 0; max-width: 55ch; }
  .rule { margin-bottom: 2.5rem; }
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.25rem, 3vw, 2rem); }
  @media (max-width: 900px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .posts-grid { grid-template-columns: 1fr; } }
</style>

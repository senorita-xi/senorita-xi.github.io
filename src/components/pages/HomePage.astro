---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategorySection from '@/components/CategorySection.astro';
import InstagramGrid from '@/components/InstagramGrid.astro';
import { getCategoryPosts } from '@/i18n/paths';
import { getLang, useTranslations, localHref } from '@/i18n/utils';

const lang = getLang(Astro.currentLocale);
const t    = useTranslations(lang);

const [footprints, savour, pagesFrames, inMotion] = await Promise.all([
  getCategoryPosts('footprints',   lang),
  getCategoryPosts('savour',       lang),
  getCategoryPosts('pages-frames', lang),
  getCategoryPosts('in-motion',    lang),
]);
---

<BaseLayout lang={lang} tagline={t('home.tagline')}>
  <!-- Instagram feed strip — full width, no header -->
  <InstagramGrid minimal />

  <!-- Category sections -->
  <div class="container">
    <CategorySection
      labelKey="nav.footprints"
      href={localHref('/footprints/', lang)}
      posts={footprints.slice(0, 3)}
    />
    <CategorySection
      labelKey="nav.savour"
      href={localHref('/savour/', lang)}
      posts={savour.slice(0, 3)}
    />
    <CategorySection
      labelKey="nav.pagesFrames"
      href={localHref('/pages-frames/', lang)}
      posts={pagesFrames.slice(0, 3)}
    />
    <CategorySection
      labelKey="nav.inMotion"
      href={localHref('/in-motion/', lang)}
      posts={inMotion.slice(0, 3)}
    />
  </div>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategorySection from '@/components/CategorySection.astro';
import InstagramGrid from '@/components/InstagramGrid.astro';
import { getCategoryPosts } from '@/i18n/paths';
import { getLang, useTranslations, localHref } from '@/i18n/utils';

const lang = getLang(Astro.currentLocale);
const t    = useTranslations(lang);

const [footprints, savour, pagesFrames, inMotion] = await Promise.all([
  getCategoryPosts('footprints',   lang),
  getCategoryPosts('savour',       lang),
  getCategoryPosts('pages-frames', lang),
  getCategoryPosts('in-motion',    lang),
]);
---

<BaseLayout lang={lang}>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1 class="hero-title">
          <span class="line-xi fade-up">ξ</span>
          <span class="line-chasing fade-up fade-up-1">Chasing</span>
          <span class="line-wanderlust fade-up fade-up-2">Wanderlust</span>
        </h1>
        <div class="hero-rule fade-up fade-up-3"></div>
        <p class="hero-sub fade-up fade-up-4">{t('home.tagline')}</p>
      </div>
    </div>
  </section>

  <!-- Category sections -->
  <div class="container">
    <CategorySection
      number="01" labelKey="nav.footprints" descKey="desc.footprints"
      href={localHref('/footprints/', lang)}
      posts={footprints.slice(0, 3)}
    />
    <CategorySection
      number="02" labelKey="nav.savour" descKey="desc.savour"
      href={localHref('/savour/', lang)}
      posts={savour.slice(0, 3)}
    />
    <CategorySection
      number="03" labelKey="nav.pagesFrames" descKey="desc.pagesFrames"
      href={localHref('/pages-frames/', lang)}
      posts={pagesFrames.slice(0, 3)}
    />
    <CategorySection
      number="04" labelKey="nav.inMotion" descKey="desc.inMotion"
      href={localHref('/in-motion/', lang)}
      posts={inMotion.slice(0, 3)}
    />
  </div>

  <InstagramGrid />
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(4rem, 10vw, 8rem);
    border-bottom: 1px solid var(--cream);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.025em;
    margin-bottom: 2rem;
  }

  .line-xi {
    font-size: clamp(2.75rem, 7vw, 5.5rem);
    font-style: italic;
    color: var(--accent);
    letter-spacing: -0.01em;
    margin-bottom: 0.1em;
  }

  .line-chasing {
    font-size: clamp(3rem, 8vw, 7rem);
    font-style: normal;
    font-weight: 400;
    color: var(--mist);
    margin-bottom: 0.05em;
  }

  .line-wanderlust {
    font-size: clamp(3rem, 8vw, 7rem);
    font-style: italic;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.03em;
  }

  .hero-rule {
    width: clamp(2.5rem, 6vw, 4.5rem);
    height: 1px;
    background-color: var(--accent);
    margin-bottom: 1.25rem;
    opacity: 0.5;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 1.8vw, 1.0625rem);
    font-style: italic;
    color: var(--mist);
    max-width: 40ch;
    line-height: 1.7;
    margin-bottom: 0;
  }
</style>

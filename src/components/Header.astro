---
import { useTranslations, localHref } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const pathname = Astro.url.pathname;

const nav = [
  { key: 'nav.footprints',  slug: 'footprints'   },
  { key: 'nav.savour',      slug: 'savour'        },
  { key: 'nav.pagesFrames', slug: 'pages-frames'  },
  { key: 'nav.inMotion',    slug: 'in-motion'     },
  { key: 'nav.contacts',    slug: 'contacts'      },
] as const;

function isActive(slug: string) {
  const href = localHref(`/${slug}/`, lang);
  return pathname === href || pathname.startsWith(href);
}

// Language switcher: toggle between /bg/... and /...
const otherLang: Lang = lang === 'en' ? 'bg' : 'en';
let switchHref: string;
if (lang === 'bg') {
  // Strip /bg prefix
  const stripped = pathname.replace(/^\/bg/, '') || '/';
  switchHref = stripped;
} else {
  // Add /bg prefix
  switchHref = `/bg${pathname === '/' ? '' : pathname}`;
  if (switchHref === '/bg') switchHref = '/bg/';
}
---

<header class="site-header">
  <div class="container header-inner">

    <a href={localHref('/', lang)} class="site-logo" aria-label="ξ Chasing Wanderlust — home">
      <span class="xi-mark">ξ</span>
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      {nav.map(({ key, slug }) => (
        <a
          href={localHref(`/${slug}/`, lang)}
          class:list={['nav-link', { active: isActive(slug) }]}
        >
          {t(key)}
        </a>
      ))}
    </nav>

    <div class="header-right">
      <!-- Language switcher -->
      <a href={switchHref} class="lang-switch" aria-label={`Switch to ${otherLang === 'bg' ? 'Bulgarian' : 'English'}`}>
        <span class:list={['lang-opt', { 'lang-active': lang === 'en' }]}>EN</span>
        <span class="lang-sep">·</span>
        <span class:list={['lang-opt', { 'lang-active': lang === 'bg' }]}>BG</span>
      </a>

      <!-- Instagram -->
      <a href="https://www.instagram.com/senorita.xi/" target="_blank" rel="noopener noreferrer" class="ig-link" aria-label="Instagram @senorita.xi">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
      </a>
    </div>

    <!-- Mobile toggle -->
    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <div class="mobile-nav" id="mobile-nav" hidden>
    <div class="container">
      {nav.map(({ key, slug }) => (
        <a
          href={localHref(`/${slug}/`, lang)}
          class:list={['mobile-nav-link', { active: isActive(slug) }]}
        >
          {t(key)}
        </a>
      ))}
      <a href="https://www.instagram.com/senorita.xi/" target="_blank" rel="noopener noreferrer" class="mobile-nav-link ig-mobile">
        @senorita.xi
      </a>
      <div class="mobile-lang">
        <a href={switchHref} class="mobile-lang-switch">
          {otherLang === 'bg' ? 'Български' : 'English'}
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(254, 252, 248, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--cream);
    height: var(--nav-h);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 100%;
  }

  .site-logo { display: flex; align-items: center; flex-shrink: 0; text-decoration: none; }
  .xi-mark { font-family: var(--font-display); font-size: 1.75rem; font-weight: 400; font-style: italic; color: var(--ink); line-height: 1; transition: color 0.2s; }
  .site-logo:hover .xi-mark { color: var(--accent); }

  .site-nav { display: flex; align-items: center; gap: 0.1rem; margin-left: auto; }

  .nav-link {
    font-family: var(--font-label);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    color: var(--mist);
    padding: 0.35rem 0.65rem;
    position: relative;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0.65rem;
    right: 0.65rem;
    height: 1px;
    background-color: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link:hover, .nav-link.active { color: var(--ink); }
  .nav-link:hover::after, .nav-link.active::after { transform: scaleX(1); }

  .header-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-left: 0.75rem;
    flex-shrink: 0;
  }

  /* Language switcher */
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    text-decoration: none;
    padding: 0.25rem 0;
  }

  .lang-opt {
    font-family: var(--font-label);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--mist);
    transition: color 0.2s;
  }

  .lang-opt.lang-active {
    color: var(--accent);
    font-weight: 600;
  }

  .lang-switch:hover .lang-opt:not(.lang-active) { color: var(--ink); }

  .lang-sep {
    font-size: 0.6rem;
    color: var(--cream);
  }

  .ig-link { display: flex; align-items: center; color: var(--mist); padding: 0.35rem; border-radius: 4px; transition: color 0.2s; }
  .ig-link:hover { color: var(--accent); }

  .menu-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 0.5rem; margin-left: 0.25rem; }
  .menu-toggle span { display: block; width: 22px; height: 1.5px; background-color: var(--ink); transition: transform 0.25s, opacity 0.25s; }
  .menu-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-nav { background-color: var(--ivory); border-bottom: 1px solid var(--cream); padding-block: 1rem; }
  .mobile-nav .container { display: flex; flex-direction: column; gap: 0.25rem; }
  .mobile-nav-link { font-family: var(--font-label); font-size: 0.9rem; letter-spacing: 0.06em; color: var(--mist); padding: 0.5rem 0; border-bottom: 1px solid var(--cream); transition: color 0.2s; }
  .mobile-nav-link:last-of-type { border-bottom: none; }
  .mobile-nav-link:hover, .mobile-nav-link.active { color: var(--accent); }
  .ig-mobile { color: var(--sage); }

  .mobile-lang { padding-top: 0.75rem; }
  .mobile-lang-switch { font-family: var(--font-label); font-size: 0.75rem; letter-spacing: 0.1em; color: var(--accent); text-decoration: none; text-transform: uppercase; }

  @media (max-width: 820px) {
    .site-nav, .header-right { display: none; }
    .menu-toggle { display: flex; margin-left: auto; }
  }
</style>

<script>
  const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement;
  const mobileNav = document.getElementById('mobile-nav') as HTMLElement;
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    mobileNav.hidden = expanded;
  });
</script>

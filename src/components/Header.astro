---
import { useTranslations, localHref } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const pathname = Astro.url.pathname;

const nav = [
  { key: 'nav.home',       slug: '',            exact: true  },
  { key: 'nav.footprints', slug: 'footprints',  exact: false },
  { key: 'nav.savour',     slug: 'savour',      exact: false },
  { key: 'nav.pagesFrames',slug: 'pages-frames',exact: false },
  { key: 'nav.inMotion',   slug: 'in-motion',   exact: false },
  { key: 'nav.contacts',   slug: 'contacts',    exact: false },
] as const;

function navHref(slug: string) {
  return slug === '' ? localHref('/', lang) : localHref(`/${slug}/`, lang);
}

function isActive(slug: string, exact: boolean) {
  const href = navHref(slug);
  return exact ? pathname === href : (pathname === href || pathname.startsWith(href));
}

// Language switcher: toggle between BG (default, /) and EN (/en/)
const otherLang: Lang = lang === 'bg' ? 'en' : 'bg';
let switchHref: string;
if (lang === 'bg') {
  // BG → EN: add /en prefix
  switchHref = pathname === '/' ? '/en/' : `/en${pathname}`;
} else {
  // EN → BG: strip /en prefix
  const stripped = pathname.replace(/^\/en/, '') || '/';
  switchHref = stripped;
}
---

<header class="site-header">
  <div class="container">

    <!-- Top row: nav (left) + lang switch (right) -->
    <div class="header-top">
      <nav class="site-nav" aria-label="Main navigation">
        {nav.map(({ key, slug, exact }) => (
          <a
            href={navHref(slug)}
            class:list={['nav-link', { active: isActive(slug, exact) }]}
          >
            {t(key)}
          </a>
        ))}
      </nav>

      <a href={switchHref} class="lang-switch" aria-label={`Switch to ${otherLang === 'bg' ? 'Bulgarian' : 'English'}`}>
        <span class:list={['lang-opt', { 'lang-active': lang === 'bg' }]}>BG</span>
        <span class="lang-sep">·</span>
        <span class:list={['lang-opt', { 'lang-active': lang === 'en' }]}>EN</span>
      </a>

      <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>

    <!-- Brand masthead -->
    <a href={localHref('/', lang)} class="header-brand" aria-label="ξ Chasing Wanderlust — home">
      <span class="brand-xi">ξ</span>
      <span class="brand-chasing">Chasing</span>
      <span class="brand-wanderlust">Wanderlust</span>
    </a>

    <hr class="header-rule" />
  </div>

  <!-- Mobile nav -->
  <div class="mobile-nav" id="mobile-nav" hidden>
    <div class="container">
      {nav.map(({ key, slug, exact }) => (
        <a
          href={navHref(slug)}
          class:list={['mobile-nav-link', { active: isActive(slug, exact) }]}
        >
          {t(key)}
        </a>
      ))}
      <div class="mobile-lang">
        <a href={switchHref} class="mobile-lang-switch">
          {otherLang === 'bg' ? 'Български' : 'English'}
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(254, 252, 248, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .container { padding-top: 0; padding-bottom: 0; }

  .header-top {
    display: flex;
    align-items: center;
    padding-block: 0.6rem;
  }

  .site-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
  }

  .nav-link {
    font-family: var(--font-label);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    color: var(--mist);
    padding: 0.3rem 0.6rem;
    position: relative;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0.6rem;
    right: 0.6rem;
    height: 1px;
    background-color: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link:hover, .nav-link.active { color: var(--ink); }
  .nav-link:hover::after, .nav-link.active::after { transform: scaleX(1); }

  /* Language switcher */
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    text-decoration: none;
    padding: 0.25rem 0;
    margin-left: auto;
    flex-shrink: 0;
  }

  .lang-opt {
    font-family: var(--font-label);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--mist);
    transition: color 0.2s;
  }

  .lang-opt.lang-active {
    color: var(--accent);
    font-weight: 600;
  }

  .lang-switch:hover .lang-opt:not(.lang-active) { color: var(--ink); }

  .lang-sep { font-size: 0.6rem; color: var(--cream); }

  /* Brand masthead */
  .header-brand {
    display: block;
    text-align: center;
    text-decoration: none;
    padding-bottom: 0.6rem;
    font-family: var(--font-display);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .brand-xi {
    font-size: 1.125rem;
    font-style: italic;
    color: var(--accent);
    margin-right: 0.2em;
  }

  .brand-chasing {
    font-size: 1.125rem;
    font-style: normal;
    font-weight: 400;
    color: var(--mist);
    margin-right: 0.2em;
  }

  .brand-wanderlust {
    font-size: 1.125rem;
    font-style: italic;
    font-weight: 700;
    color: var(--ink);
  }

  .header-rule {
    border: none;
    border-top: 1px solid var(--cream);
  }

  /* Mobile */
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-left: 0.5rem;
  }
  .menu-toggle span { display: block; width: 22px; height: 1.5px; background-color: var(--ink); transition: transform 0.25s, opacity 0.25s; }
  .menu-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-nav { background-color: var(--ivory); border-bottom: 1px solid var(--cream); padding-block: 1rem; }
  .mobile-nav .container { display: flex; flex-direction: column; gap: 0.25rem; }
  .mobile-nav-link { font-family: var(--font-label); font-size: 0.9rem; letter-spacing: 0.06em; color: var(--mist); padding: 0.5rem 0; border-bottom: 1px solid var(--cream); transition: color 0.2s; }
  .mobile-nav-link:last-of-type { border-bottom: none; }
  .mobile-nav-link:hover, .mobile-nav-link.active { color: var(--accent); }

  .mobile-lang { padding-top: 0.75rem; }
  .mobile-lang-switch { font-family: var(--font-label); font-size: 0.75rem; letter-spacing: 0.1em; color: var(--accent); text-decoration: none; text-transform: uppercase; }

  @media (max-width: 820px) {
    .site-nav, .lang-switch { display: none; }
    .menu-toggle { display: flex; margin-left: auto; }
  }
</style>

<script>
  const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement;
  const mobileNav = document.getElementById('mobile-nav') as HTMLElement;
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    mobileNav.hidden = expanded;
  });
</script>

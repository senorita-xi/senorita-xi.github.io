---
import BaseLayout from './BaseLayout.astro';
import { getLang, useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

interface Props {
  title: string;
  description: string;
  coverImage: string;
  pubDate: Date;
  category: string;
  location?: string;
  categoryHref: string;
  categoryLabel: string;
  lang?: Lang;
  isFallback?: boolean;
}

const { title, description, coverImage, pubDate, category, location, categoryHref, categoryLabel, lang: langProp, isFallback = false } = Astro.props;
const lang = langProp ?? getLang(Astro.currentLocale);
const t    = useTranslations(lang);
const locale = lang === 'bg' ? 'bg-BG' : 'en-US';

const formattedDate = pubDate.toLocaleDateString(locale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout lang={lang} title={`${title} — ξ Chasing Wanderlust`} description={description} image={coverImage} showHero={false}>
  <article class="post-page">
    <!-- Hero image -->
    <div class="post-hero fade-up fade-up-1">
      <img
        src={coverImage}
        alt={title}
        class="post-hero-image"
        width="1200"
        height="630"
      />
    </div>

    <!-- Header: breadcrumb + title + meta -->
    <div class="container post-header fade-up">
      <div class="post-breadcrumb">
        <a href={categoryHref} class="back-link">← {categoryLabel}</a>
      </div>

      {isFallback && (
        <div class="fallback-notice">{t('ui.fallbackNotice')}</div>
      )}

      <div class="post-meta-row">
        {location && <span class="post-location">{location}</span>}
        {location && <span class="meta-sep">·</span>}
        <time class="post-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
      </div>

      <h1 class="post-title">{title}</h1>
      <p class="post-description">{description}</p>
    </div>

    <!-- Body -->
    <div class="container">
      <hr class="post-rule" />
      <div class="prose fade-up fade-up-2">
        <slot />
      </div>
    </div>

    <!-- Back link -->
    <div class="container post-footer fade-up fade-up-3">
      <a href={categoryHref} class="back-link-bottom">← {t('ui.backTo')} {categoryLabel}</a>
    </div>
  </article>
</BaseLayout>

<style>
  .post-page {
    padding-bottom: clamp(3rem, 8vw, 6rem);
  }

  .post-header {
    padding-top: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .post-breadcrumb {
    margin-bottom: 1.5rem;
  }

  .fallback-notice {
    display: inline-block;
    margin-bottom: 1rem;
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--ivory);
    background-color: var(--mist);
    padding: 0.35rem 0.75rem;
    border-radius: 2px;
  }

  .back-link {
    font-family: var(--font-label);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    color: var(--mist);
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--accent); }

  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .post-location {
    font-family: var(--font-label);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .meta-sep { color: var(--cream); font-size: 0.7rem; }

  .post-date {
    font-family: var(--font-label);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: var(--mist);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 1rem;
    max-width: 20ch;
  }

  .post-description {
    font-size: 1.0625rem;
    color: var(--mist);
    line-height: 1.65;
    max-width: 55ch;
    font-style: italic;
    margin-bottom: 0;
  }

  /* Hero image — full width, no rounded corners */
  .post-hero {
    width: 100%;
    max-height: 55vh;
    overflow: hidden;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .post-hero-image {
    width: 100%;
    height: 55vh;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .post-rule {
    border: none;
    border-top: 1px solid var(--cream);
    margin-bottom: clamp(2rem, 4vw, 3rem);
    margin-top: clamp(1.5rem, 3vw, 2rem);
  }

  .post-footer {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    padding-top: 2rem;
    border-top: 1px solid var(--cream);
  }

  .back-link-bottom {
    font-family: var(--font-label);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    color: var(--mist);
    transition: color 0.2s;
  }
  .back-link-bottom:hover { color: var(--accent); }
</style>

---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  coverImage: string;
  pubDate: Date;
  category: string;
  location?: string;
  categoryHref: string;
  categoryLabel: string;
}

const { title, description, coverImage, pubDate, category, location, categoryHref, categoryLabel } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — ξ Chasing Wanderlust`} description={description} image={coverImage}>
  <article class="post-page">
    <!-- Hero -->
    <div class="post-hero fade-up">
      <div class="post-hero-image-wrap">
        <img
          src={coverImage}
          alt={title}
          class="post-hero-image"
          width="1200"
          height="630"
        />
      </div>
    </div>

    <!-- Header -->
    <div class="container post-header fade-up fade-up-1">
      <div class="post-breadcrumb">
        <a href={categoryHref} class="back-link">← {categoryLabel}</a>
      </div>

      <div class="post-meta-row">
        {location && <span class="post-location">{location}</span>}
        {location && <span class="meta-sep">·</span>}
        <time class="post-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
      </div>

      <h1 class="post-title">{title}</h1>
      <p class="post-description">{description}</p>
      <hr class="post-rule" />
    </div>

    <!-- Body -->
    <div class="container">
      <div class="prose fade-up fade-up-2">
        <slot />
      </div>
    </div>

    <!-- Back link -->
    <div class="container post-footer fade-up fade-up-3">
      <a href={categoryHref} class="back-link-bottom">← Back to {categoryLabel}</a>
    </div>
  </article>
</BaseLayout>

<style>
  .post-page {
    padding-bottom: clamp(3rem, 8vw, 6rem);
  }

  .post-hero {
    width: 100%;
    max-height: 60vh;
    overflow: hidden;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .post-hero-image-wrap {
    width: 100%;
    height: 60vh;
    overflow: hidden;
  }

  .post-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .post-header {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .post-breadcrumb {
    margin-bottom: 1.5rem;
  }

  .back-link {
    font-family: var(--font-label);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    color: var(--mist);
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--sienna); }

  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .post-location {
    font-family: var(--font-label);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sienna);
  }

  .meta-sep { color: var(--cream); font-size: 0.7rem; }

  .post-date {
    font-family: var(--font-label);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: var(--mist);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 1rem;
    max-width: 20ch;
  }

  .post-description {
    font-size: 1.0625rem;
    color: var(--mist);
    line-height: 1.65;
    max-width: 55ch;
    font-style: italic;
    margin-bottom: 2rem;
  }

  .post-rule {
    border: none;
    border-top: 1px solid var(--cream);
    margin-bottom: 0;
  }

  .post-footer {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    padding-top: 2rem;
    border-top: 1px solid var(--cream);
  }

  .back-link-bottom {
    font-family: var(--font-label);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    color: var(--mist);
    transition: color 0.2s;
  }

  .back-link-bottom:hover { color: var(--sienna); }
</style>
